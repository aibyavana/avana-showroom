{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "avana-showroom",
  "compatibility_date": "2026-06-24",
  "compatibility_flags": ["nodejs_compat"],
  "main": ".output/server/index.mjs",
  "no_bundle": true,
  "rules": [
    { "type": "ESModule", "globs": ["**/*.mjs", "**/*.js"] }
  ],
  "assets": {
    "directory": ".output/public",
    "binding": "ASSETS"
  },
  "observability": {
    "enabled": true
  }
}
